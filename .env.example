NODE_ENV=development
PORT=8000
API_PREFIX=api

MONGODB_URI=mongodb://127.0.0.1:27017/zaxira

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

SUPER_ADMIN_LOGIN=admin
SUPER_ADMIN_PASSWORD=123123

CORS_ORIGIN=http://localhost:5173
# QR kodlar va ochiq havolalar uchun frontend domeni (domen o‘zgarganda shu yerni yangilang)
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000/api
ORGANIZATION_FULL_NAME_LATIN="Toshkent metropoliteni" DUK
# Socket.IO (frontend VITE_WS_URL) — odatda API host bilan bir xil

THROTTLE_TTL=60000
THROTTLE_LIMIT=120

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Google Shopping narx qidiruvi (https://serpapi.com — bepul reja mavjud)
SERPAPI_API_KEY=
# Windows/antivirus SSL xatosi bo‘lsa (UNABLE_TO_VERIFY_LEAF_SIGNATURE):
# SERPAPI_TLS_INSECURE=true

# AI matn yaxshilash (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Tavsiya etilgan bepul model:
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
