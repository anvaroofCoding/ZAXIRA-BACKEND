NODE_ENV=development
PORT=8000
API_PREFIX=api

MONGODB_URI=mongodb://127.0.0.1:27017/zaxira

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

SUPER_ADMIN_LOGIN=admin
SUPER_ADMIN_PASSWORD=123123

CORS_ORIGIN=http://localhost:5173
# Socket.IO (frontend VITE_WS_URL) — odatda API host bilan bir xil

THROTTLE_TTL=60000
THROTTLE_LIMIT=120

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
